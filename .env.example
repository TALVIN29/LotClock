# Copy to .env and fill in. .env is gitignored — never commit real values.
# In GitHub these live in: Settings → Secrets and variables → Actions

# Supabase → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# healthchecks.io ping URL (dead-man's switch). Optional but recommended.
HEALTHCHECK_URL=

# Scraper behaviour — defaults are fine
SCRAPER_USER_AGENT=LotClock/0.1 (+https://github.com/TALVIN29/LotClock)
SCRAPE_DELAY_SECONDS=5
SCRAPE_MAX_LISTINGS=2000
SCRAPE_MIN_EXPECTED=200
